# ============================================================
# 面向三农场景的直播电商AI辅助平台 — 环境变量配置
# ============================================================
# 使用方式：
#   1. 复制此文件为 .env：  cp .env.example .env
#   2. 填入你的 API Key
#   3. 启动平台：python backend/main.py
# ============================================================

# ---- 方式一：阿里云百炼（推荐，国内用户） ----
# 注册地址: https://bailian.console.aliyun.com/
# 模型: qwen3.5-omni-plus（多模态）、qwen-plus（纯文本）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# ---- 方式二：OpenAI 官方 ----
# 注册地址: https://platform.openai.com/api-keys
# 模型: gpt-4o、gpt-4o-mini 等
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ---- 方式三：其他 OpenAI 兼容接口 ----
# 支持任何兼容 OpenAI API 格式的服务（如本地 Ollama、vLLM 等）
# LLM_API_KEY=your-api-key-here
# LLM_BASE_URL=https://your-custom-endpoint.com/v1

# ---- 模型选择 ----
# 可选值: qwen3.5-omni-plus, gpt-4o, deepseek-chat 等
MODEL_NAME=qwen3.5-omni-plus

# ---- 服务配置（可选） ----
# PORT=8000
# DEBUG=true
# MAX_AI_RETRIES=2
# MAX_SCREENSHOTS=200
